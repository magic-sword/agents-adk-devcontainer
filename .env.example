# Docker Composeプロジェクト名（コンテナ名の衝突を防ぐためのプレフィックスとして使用されます）
# 空白のままにすると、親ディレクトリ名がデフォルトのプロジェクト名として使用されます。
COMPOSE_PROJECT_NAME=my-agent-project

# Google Cloudの設定
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Gemini APIの設定（Google Cloud Vertex AIのADCを使用しない場合）
GEMINI_API_KEY=your-gemini-api-key

# エージェントの設定
AGENT_NAME=my-agent

# =========================================================================
# パッケージ公開用の環境変数 (edd-agent-tools を PyPI 等へアップロードする場合に設定します)
# =========================================================================
# PyPI の場合は "__token__"、Artifact Registry の場合は "oauth2accesstoken" を指定します
TWINE_USERNAME=__token__
# PyPIのAPIトークン (pypi-...) または一時アクセストークンを指定します
TWINE_PASSWORD=your-pypi-api-token
# プライベートリポジトリ（Artifact Registry等）を使用する場合にそのURLを指定します
# TWINE_REPOSITORY_URL=https://<LOCATION>-python.pkg.dev/<PROJECT_ID>/<REPOSITORY_NAME>/

# =========================================================================
# Agent Registry 登録・公開用の環境変数 (gcloudでの登録コマンド実行時などに使用します)
# =========================================================================
# 登録先の Google Cloud プロジェクトID (未指定時はGCP_PROJECT_IDを使用)
AGENT_REGISTRY_PROJECT_ID=your-gcp-project-id
# 登録先のリージョン・ロケーション (例: global, us-central1)
AGENT_REGISTRY_LOCATION=global
# Agent Registry での表示名称
AGENT_REGISTRY_DISPLAY_NAME="Evaluation Driven Development Agent"


# Docker Compose Project Name (used as container prefix to prevent name conflicts)
# If left empty, the parent directory name will be used as the default project name.
COMPOSE_PROJECT_NAME=my-agent-project

# Google Cloud Settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Gemini API Configuration (if not using Google Cloud Vertex AI ADC)
GEMINI_API_KEY=your-gemini-api-key

# Agent Configuration
AGENT_NAME=my-agent

# Path to host's Gemini/Antigravity global config directory (e.g. C:\Users\<Username>\.gemini\config on Windows)
# If left empty, a dummy directory (.gemini_config_dummy) inside the workspace will be mounted instead.
HOST_GEMINI_CONFIG_DIR=

